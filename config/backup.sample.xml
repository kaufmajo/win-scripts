<settings>
  <enableNetworkForwarding>true</enableNetworkForwarding>

  <masterdrive>
    <letter>x</letter>
    <description>masterdrive</description>
    <bitlocker>true</bitlocker>
    <envvar>master_password_env</envvar>
  </masterdrive>

  <slavedrive>
    <letter>y</letter>
    <description>slavedrive</description>
    <bitlocker>true</bitlocker>
    <envvar>slave_password_env</envvar>
  </slavedrive>

  <folder>
    <rootfolder>c:\path\to\root</rootfolder>
    <timelineFolder>c:\path\to\timeline</timelineFolder>
    <wslExportFolder>c:\path\to\wsl</wslExportFolder>
    <hyperVPoolFolder>c:\path\to\hyperv\pool</hyperVPoolFolder>
    <hyperVExportFolder>c:\path\to\hyperv\export</hyperVExportFolder>
  </folder>

  <script>
    <unlockMasterDrive>c:\path\to\script.ps1</unlockMasterDrive>
  </script>

  <robocopy>
    <job>
      <type>backup</type>
      <name>backup_job</name>
      <source>source_path</source>
      <target>target_path</target>
      <file></file>
      <options>robocopy_options</options>
    </job>
    <job>
      <type>backup</type>
      <name>backup_job</name>
      <source>source_path</source>
      <target>target_path</target>
      <file></file>
      <options>robocopy_options</options>
    </job>
    <job>
      <type>config</type>
      <name>config_job</name>
      <source>source_path</source>
      <target>target_path</target>
      <file>filename</file>
      <options>robocopy_options</options>
    </job>
  </robocopy>

  <rsync>
    <job>
      <type>config</type>
      <name>sync_job</name>
      <source>user@host:/path</source>
      <target>/path/to/target</target>
      <options>rsync_options</options>
    </job>
    <job>
      <type>config</type>
      <name>sync_job</name>
      <source>user@host:/path</source>
      <target>/path/to/target</target>
      <options>rsync_options</options>
    </job>
  </rsync>

  <wslExport>
    <job>
      <name>distro_name</name>
    </job>
    <job>
      <name>distro_name</name>
    </job>
  </wslExport>

  <hyperVExport>
    <job>
      <name>vm_name</name>
    </job>
    <job>
      <name>vm_name</name>
    </job>
  </hyperVExport>

</settings>